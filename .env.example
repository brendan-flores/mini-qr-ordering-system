# Copy to .env.local for local development.
# On Vercel: Project → Settings → Environment Variables (add the same keys).

# Customer menu site (QR codes, public ordering). Production: https://brencravings.vercel.app
# Localhost dev: http://localhost:3000
# LAN / phone testing: use your PC's Wi-Fi IP so printed QRs work on phones, e.g. http://192.168.1.10:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin dashboard site. Production: https://brencravings-admin.vercel.app
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3000

# Leave empty for same-origin API (recommended on Vercel). Do not point to localhost:4000 in production.
NEXT_PUBLIC_API_BASE_URL=

# MySQL (required) — run mysql/schema.sql in MySQL Workbench first.
# Always 127.0.0.1 on the machine running npm run dev; LAN guests use the Next.js URL, not MySQL directly.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mini_qr_ordering

# Railway on Vercel: use MYSQL_PUBLIC_URL or public host — NOT mysql.railway.internal
# MYSQL_PUBLIC_URL=mysql://user:pass@xxxx.proxy.rlwy.net:PORT/railway
# MYSQL_SSL=true

# Admin session signing (required in production; use a long random string)
ADMIN_SESSION_SECRET=

# Optional: machine-to-machine admin API access (same value in x-admin-key header)
ADMIN_API_KEY=
NEXT_PUBLIC_ADMIN_API_KEY=
