# Copy to .env.local for local development.
# On Vercel: Project → Settings → Environment Variables (add the same keys).

# Public site URL (used for QR codes). On Vercel, set to your production URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Leave empty for same-origin API (recommended on Vercel). Do not point to localhost:4000 in production.
NEXT_PUBLIC_API_BASE_URL=

# Supabase — add to .env or .env.local (service_role key from Supabase → Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
